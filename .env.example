# Blinkit App Review — environment template
# Copy to `.env` and fill in values. Never commit a real `.env`.

# --- Groq LLM ---
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: alternate Groq model for lighter/faster calls
# GROQ_MODEL_FAST=llama-3.1-8b-instant

# --- Runtime ---
APP_ENV=development
RUN_ID=2026-07-16-weekly
